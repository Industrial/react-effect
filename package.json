{
	"name": "effect-react",
	"version": "0.1.0",
	"description": "Effect.ts integration for React – hooks and runtime mirroring useTransition, useActionState, useOptimistic, and more",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": ["dist", "README.md"],
	"scripts": {
		"build": "tsc",
		"lint": "biome check .",
