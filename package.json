		"test": "bun test"
	},
	"peerDependencies": {
		"effect": ">=3.0.0",
		"react": ">=18.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.13",
		"@types/bun": "latest",
		"@types/react": "^18.2.0",
		"effect": "^3.11.0",
		"react": "^18.2.0",
		"typescript": "^5.2.0"
	},
	"keywords": ["effect", "react", "hooks", "useTransition", "useActionState", "useOptimistic"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/your-org/effect-react.git"
